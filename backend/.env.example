# LaunchLab Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model for all LLM calls (agent, patient simulator, judge)
# Default: claude-sonnet-4-5-20250929 (recommended for best quality)
# Alternative: claude-sonnet-4-20250514 (lower cost)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Database URL (SQLite via aiosqlite)
DATABASE_URL=sqlite+aiosqlite:///./data/launchlab.db

# Environment: development | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# CORS allowed origins (comma-separated)
# Development: http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173
